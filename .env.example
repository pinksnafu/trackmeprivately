DATABASE_URL="file:./dev.db"
NEXTAUTH_SECRET="replace-with-a-strong-random-secret"
ALLOWED_RP_ID="localhost"
ALLOWED_RP_ORIGIN="http://localhost:3000"

# Session cookie hardening
# Defaults to 30 days in seconds.
SESSION_MAX_AGE="2592000"
# Allowed values: lax, strict, none. Use strict for same-site admin panels.
SESSION_COOKIE_SAME_SITE="lax"
# Optional. Leave unset unless you need to scope cookies to a parent domain.
# SESSION_COOKIE_DOMAIN=".example.com"

# Analytics Data Retention
# Optional. Set to a positive integer to delete events older than this number of days when running prune script.
# ANALYTICS_RETENTION_DAYS="90"
